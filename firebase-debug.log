[debug] [2026-03-25T14:05:16.177Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/music-team-organizer/rulesets {"name":"projects/music-team-organizer/rulesets/0744c086-4c59-4b02-9715-1b8440ca4eb2","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // ─── Helper functions ────────────────────────────────────────────────────\r\n\r\n    // Is the request from a signed-in user?\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // Does the signed-in user own this uid document?\r\n    function isOwner(uid) {\r\n      return isSignedIn() && request.auth.uid == uid;\r\n    }\r\n\r\n    // Read the team document (used in subcollection rules)\r\n    function getTeam(teamId) {\r\n      return get(/databases/$(database)/documents/teams/$(teamId)).data;\r\n    }\r\n\r\n    // Is the team marked public (default true if field absent)?\r\n    function isTeamPublic(teamId) {\r\n      let team = getTeam(teamId);\r\n      return !('isPublic' in team) || team.isPublic == true;\r\n    }\r\n\r\n    // Is the signed-in user the creator of the team?\r\n    // Checks both uid (new teams) and email (legacy teams where createdBy stored email).\r\n    function isTeamCreator(teamId) {\r\n      let team = getTeam(teamId);\r\n      return isSignedIn() && (\r\n        team.createdBy == request.auth.uid ||\r\n        (\r\n          ('createdByEmail' in team) &&\r\n          team.createdByEmail == request.auth.token.email\r\n        )\r\n      );\r\n    }\r\n\r\n    // Is the signed-in user listed in the team's adminUids array?\r\n    // Guards against missing/null adminUids field.\r\n    function isTeamAdmin(teamId) {\r\n      let team = getTeam(teamId);\r\n      return isSignedIn() &&\r\n        ('adminUids' in team) &&\r\n        team.adminUids != null &&\r\n        request.auth.uid in team.adminUids;\r\n    }\r\n\r\n    // Is the signed-in user a member of the team?\r\n    function isMemberOfTeam(teamId) {\r\n      return isSignedIn() &&\r\n        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\r\n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId;\r\n    }\r\n\r\n    // Can the user write to this team (creator OR in adminUids)?\r\n    function canWriteTeam(teamId) {\r\n      return isTeamCreator(teamId) || isTeamAdmin(teamId);\r\n    }\r\n\r\n    // ─── /users/{uid} ────────────────────────────────────────────────────────\r\n    match /users/{uid} {\r\n      allow read, write: if isOwner(uid);\r\n    }\r\n\r\n    // ─── /teams/{teamId} ─────────────────────────────────────────────────────\r\n    match /teams/{teamId} {\r\n      allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n      allow create: if isSignedIn();\r\n      allow update, delete: if canWriteTeam(teamId);\r\n\r\n      // ─── /teams/{teamId}/members ─────────────────────────────────────────\r\n      match /members/{memberId} {\r\n        allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n        allow write: if canWriteTeam(teamId);\r\n      }\r\n\r\n      // ─── /teams/{teamId}/lineups ─────────────────────────────────────────\r\n      match /lineups/{lineupId} {\r\n        allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n        allow write: if canWriteTeam(teamId);\r\n      }\r\n    }\r\n\r\n    // ─── Deny everything else ────────────────────────────────────────────────\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-03-25T14:05:16.198687Z","metadata":{"services":["cloud.firestore"]}}
