[debug] [2026-03-25T13:40:56.172Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/music-team-organizer/rulesets {"name":"projects/music-team-organizer/rulesets/67fe32d0-b34e-47b5-aaff-c904be05a118","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice firebase.storage {\r\n  match /b/{bucket}/o {\r\n\r\n    // ─── Team logos ──────────────────────────────────────────────────────────\r\n    // Path: team-logos/{teamId}/logo.jpg\r\n    match /team-logos/{teamId}/{fileName} {\r\n      // Anyone can read a team logo (logos are always public).\r\n      allow read: if true;\r\n\r\n      // Only a signed-in user who is the team creator or admin can upload.\r\n      allow write: if request.auth != null\r\n        && (\r\n          firestore.get(/databases/(default)/documents/teams/$(teamId)).data.createdBy == request.auth.uid\r\n          || request.auth.uid in firestore.get(/databases/(default)/documents/teams/$(teamId)).data.adminUids\r\n        )\r\n        // Limit file size to 5 MB and allow only image types.\r\n        && request.resource.size <= 5 * 1024 * 1024\r\n        && request.resource.contentType.matches('image/.*');\r\n    }\r\n\r\n    // ─── Deny everything else ────────────────────────────────────────────────\r\n    match /{allPaths=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"storage.rules"}]},"createTime":"2026-03-25T13:40:56.084991Z","metadata":{"services":["firebase.storage"]}}
