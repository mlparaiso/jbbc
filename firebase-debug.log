[debug] [2026-03-25T13:40:58.718Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/music-team-organizer/rulesets {"name":"projects/music-team-organizer/rulesets/15760145-ffc5-43e7-8d6a-d5a51c494b4b","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // ─── Helper functions ────────────────────────────────────────────────────\r\n\r\n    // Is the request from a signed-in user?\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // Does the signed-in user own this uid document?\r\n    function isOwner(uid) {\r\n      return isSignedIn() && request.auth.uid == uid;\r\n    }\r\n\r\n    // Read the team document (used in subcollection rules)\r\n    function getTeam(teamId) {\r\n      return get(/databases/$(database)/documents/teams/$(teamId)).data;\r\n    }\r\n\r\n    // Is the team marked public (default true if field absent)?\r\n    function isTeamPublic(teamId) {\r\n      let team = getTeam(teamId);\r\n      return !('isPublic' in team) || team.isPublic == true;\r\n    }\r\n\r\n    // Is the signed-in user the creator of the team?\r\n    function isTeamCreator(teamId) {\r\n      return isSignedIn() && getTeam(teamId).createdBy == request.auth.uid;\r\n    }\r\n\r\n    // Is the signed-in user listed in the team's adminUids array?\r\n    function isTeamAdmin(teamId) {\r\n      return isSignedIn() && request.auth.uid in getTeam(teamId).adminUids;\r\n    }\r\n\r\n    // Is the signed-in user a member of the team?\r\n    // We check the users/{uid}.teamId field to avoid an extra read.\r\n    function isMemberOfTeam(teamId) {\r\n      return isSignedIn() &&\r\n        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\r\n        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId;\r\n    }\r\n\r\n    // Can the user write to this team (creator OR in adminUids)?\r\n    function canWriteTeam(teamId) {\r\n      return isTeamCreator(teamId) || isTeamAdmin(teamId);\r\n    }\r\n\r\n    // ─── /users/{uid} ────────────────────────────────────────────────────────\r\n    // Each user can read/write only their own document.\r\n    match /users/{uid} {\r\n      allow read, write: if isOwner(uid);\r\n    }\r\n\r\n    // ─── /teams/{teamId} ─────────────────────────────────────────────────────\r\n    match /teams/{teamId} {\r\n      // Anyone (even unauthenticated) can read a public team document.\r\n      // Private teams can only be read by members.\r\n      allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n\r\n      // Any signed-in user can create a new team.\r\n      allow create: if isSignedIn();\r\n\r\n      // Only the creator or an admin can update/delete the team.\r\n      allow update, delete: if canWriteTeam(teamId);\r\n\r\n      // ─── /teams/{teamId}/members ─────────────────────────────────────────\r\n      match /members/{memberId} {\r\n        // Public teams: anyone can read members.\r\n        // Private teams: only team members can read.\r\n        allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n\r\n        // Only admins can write members.\r\n        allow write: if canWriteTeam(teamId);\r\n      }\r\n\r\n      // ─── /teams/{teamId}/lineups ─────────────────────────────────────────\r\n      match /lineups/{lineupId} {\r\n        // Public teams: anyone can read lineups.\r\n        // Private teams: only team members can read.\r\n        allow read: if isTeamPublic(teamId) || isMemberOfTeam(teamId);\r\n\r\n        // Only admins can write lineups.\r\n        allow write: if canWriteTeam(teamId);\r\n      }\r\n    }\r\n\r\n    // ─── Deny everything else ────────────────────────────────────────────────\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-03-25T13:40:58.658383Z","metadata":{"services":["cloud.firestore"]}}
